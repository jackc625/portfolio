---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.data.title} — Jack Cutrara`}
  description="Jack Cutrara — project case study. Site is being redesigned."
>
  <section style="padding: 96px 48px; max-width: 1200px; margin: 0 auto;">
    <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--ink); letter-spacing: -0.02em;">
      {project.data.title} — redesigning
    </h1>
    <p style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.6; color: var(--ink-muted); margin-top: 16px; max-width: 68ch;">
      This case study will return when the editorial redesign ships. Check back soon.
    </p>
  </section>
</BaseLayout>
