---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleImage from "../../components/ArticleImage.astro";
import NextProject from "../../components/NextProject.astro";
import JsonLd from "../../components/JsonLd.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((project, index) => {
    const nextProject = sorted[(index + 1) % sorted.length];
    return {
      params: { id: project.id },
      props: { project, nextProject },
    };
  });
}

const { project, nextProject } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <JsonLd
    schema={{
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      name: project.data.title,
      description: project.data.tagline,
      url: `https://jackcutrara.com/projects/${project.id}`,
      author: {
        "@type": "Person",
        name: "Jack Cutrara",
      },
      keywords: project.data.techStack.join(", "),
      ...(project.data.githubUrl
        ? {
            codeRepository: project.data.githubUrl,
          }
        : {}),
      ...(project.data.demoUrl
        ? {
            url: project.data.demoUrl,
          }
        : {}),
    }}
  />
  <!-- Hero Section -->
  <section
    class="px-6 pt-[var(--token-space-section)] pb-[var(--token-space-2xl)] md:px-10 lg:px-16"
  >
    <div class="mx-auto max-w-[90rem]">
      <!-- Back link -->
      <a
        href="/projects"
        class="group text-text-muted hover:text-accent mb-[var(--token-space-2xl)] inline-flex items-center gap-[var(--token-space-sm)] font-mono text-[length:var(--token-text-sm)] transition-colors duration-200"
      >
        <svg
          class="h-4 w-4 transition-transform duration-200 group-hover:-translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        Back to Projects
      </a>

      <!-- Title -->
      <h1
        data-animate="split-text"
        class="font-display text-[length:var(--token-text-display)] leading-[0.95] tracking-[-0.03em]"
      >
        {project.data.title}
      </h1>

      <!-- Tagline -->
      <p
        class="font-body text-text-secondary mt-[var(--token-space-md)] text-[length:var(--token-text-heading)]"
      >
        {project.data.tagline}
      </p>

      <!-- Tech tags -->
      <p
        class="text-text-muted mt-[var(--token-space-lg)] font-mono text-[length:var(--token-text-sm)]"
      >
        {project.data.techStack.join(", ")}
      </p>

      <!-- Links row (conditional) -->
      {
        (project.data.githubUrl || project.data.demoUrl) && (
          <div class="mt-[var(--token-space-lg)] flex items-center gap-[var(--token-space-xl)]">
            {project.data.githubUrl && (
              <a
                href={project.data.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-body text-accent hover:text-accent-hover border-accent/30 hover:border-accent border-b text-[length:var(--token-text-sm)] tracking-[0.08em] uppercase transition-colors duration-200"
              >
                View Source
              </a>
            )}
            {project.data.demoUrl && (
              <a
                href={project.data.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-body text-accent hover:text-accent-hover border-accent/30 hover:border-accent border-b text-[length:var(--token-text-sm)] tracking-[0.08em] uppercase transition-colors duration-200"
              >
                Live Demo
              </a>
            )}
          </div>
        )
      }
    </div>
  </section>

  <!-- Hero image (conditional) -->
  {
    project.data.thumbnail && (
      <div class="px-6 pb-[var(--token-space-2xl)] md:px-10 lg:px-16">
        <div class="mx-auto max-w-[90rem]">
          <Image
            src={project.data.thumbnail}
            alt={project.data.title}
            class="aspect-video w-full rounded object-cover"
          />
        </div>
      </div>
    )
  }

  <!-- MDX body content -->
  <article
    data-animate="section"
    class="px-6 pb-[var(--token-space-section)] md:px-10 lg:px-16"
  >
    <div class="mx-auto max-w-[90rem]">
      <div class="case-study-prose max-w-3xl">
        <Content components={{ img: ArticleImage }} />
      </div>
    </div>
  </article>

  <!-- Next project navigation -->
  <NextProject project={nextProject} />
</BaseLayout>

<style>
  .case-study-prose :global(h2) {
    font-family: var(--font-mono);
    font-size: var(--token-text-sm);
    color: var(--token-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--token-space-section);
    margin-bottom: var(--token-space-lg);
    font-weight: 400;
  }

  .case-study-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .case-study-prose :global(p) {
    font-family: var(--font-body);
    font-size: var(--token-text-base);
    color: var(--token-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--token-space-lg);
  }

  .case-study-prose :global(strong) {
    color: var(--token-text-primary);
  }

  .case-study-prose :global(a) {
    color: var(--token-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .case-study-prose :global(a:hover) {
    color: var(--token-accent-hover);
  }

  .case-study-prose :global(ul),
  .case-study-prose :global(ol) {
    color: var(--token-text-secondary);
    margin-left: var(--token-space-lg);
    margin-bottom: var(--token-space-lg);
  }

  .case-study-prose :global(li) {
    margin-bottom: var(--token-space-sm);
  }

  .case-study-prose :global(blockquote) {
    border-left: 2px solid oklch(0.7 0.1 250 / 0.3);
    padding-left: var(--token-space-lg);
    font-style: italic;
    color: var(--token-text-muted);
  }
</style>
