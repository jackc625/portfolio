---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillGroup from "../components/SkillGroup.astro";
---

<BaseLayout
  title="About"
  description="Learn about Jack Cutrara's background, education, and path into software engineering."
>
  <!-- ═══════════════════════════════════════════
       OPENING — Asymmetric display headline
       Large statement offset to the right, metadata at left margin
       Inspired by artemshcherban.com + bettinasosa.com dramatic type
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[60vh] flex flex-col justify-end px-6 md:px-12 lg:px-20 pb-12 md:pb-20">
    <!-- Metadata — left-aligned, small mono -->
    <div class="mb-8 md:mb-12 md:ml-0">
      <span class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.25em]">
        New York, NY
      </span>
      <span class="mx-4 text-border hidden md:inline" aria-hidden="true">/</span>
      <span class="block md:inline mt-1 md:mt-0 font-mono text-[length:var(--token-text-sm)] text-accent uppercase tracking-[0.25em]">
        Open to Opportunities
      </span>
    </div>

    <!-- Headline — pushed right on desktop for asymmetry -->
    <h1 class="md:ml-[15vw] lg:ml-[20vw]">
      <span
        class="block font-display leading-[0.9] tracking-[-0.04em]"
        style="font-size: clamp(2.5rem, 1.5rem + 8vw, 8rem);"
      >
        Building things
      </span>
      <span
        class="block font-display leading-[0.9] tracking-[-0.04em] text-accent italic"
        style="font-size: clamp(2.5rem, 1.5rem + 8vw, 8rem);"
      >
        is how I learn.
      </span>
    </h1>
  </section>

  <!-- ═══════════════════════════════════════════
       NARRATIVE — Two-register layout
       Desktop: narrow prose column offset right with sticky sidebar metadata at left
       Mobile: stacked vertically
       Inspired by aither.co's spatial depth + shiyunlu.com asymmetry
       ═══════════════════════════════════════════ -->
  <section
    aria-label="Background"
    class="relative border-t border-border"
    style="padding-top: clamp(4rem, 3rem + 5vw, 10rem); padding-bottom: clamp(4rem, 3rem + 5vw, 10rem);"
  >
    <div class="px-6 md:px-12 lg:px-20">
      <!-- Desktop: sidebar left, narrative right with asymmetric offset -->
      <div class="md:grid md:grid-cols-12 md:gap-8 lg:gap-12">

        <!-- Left margin annotations — metadata as editorial footnotes -->
        <aside class="hidden md:block md:col-span-3 lg:col-span-2">
          <div class="sticky top-24 space-y-10">
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Focus</span>
              <span class="block font-body text-[length:var(--token-text-sm)] text-text-primary">Full-Stack Development</span>
            </div>
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Education</span>
              <span class="block font-body text-[length:var(--token-text-sm)] text-text-primary">Computer Science</span>
            </div>
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Interests</span>
              <span class="block font-body text-[length:var(--token-text-sm)] text-text-primary">Open Source, New Tech</span>
            </div>
          </div>
        </aside>

        <!-- Narrative prose — narrow column, offset right -->
        <div class="md:col-span-9 lg:col-start-4 lg:col-span-7" style="max-width: 38rem;">

          <!-- Lead paragraph — serif display type, larger -->
          <p class="font-display text-[clamp(1.25rem,1rem+1.5vw,1.75rem)] leading-[1.35] text-text-primary mb-10 md:mb-16">
            I'm Jack Cutrara, a software engineer who got into programming because
            I wanted to build things &mdash; not just read about them.
          </p>

          <!-- Accent divider -->
          <span class="block w-16 h-px bg-accent mb-10 md:mb-16" aria-hidden="true"></span>

          <!-- Body paragraphs — sans, smaller, generous leading -->
          <div class="space-y-6">
            <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
              I studied computer science at university, where I discovered that the
              best way to learn was to ship real projects. That mindset stuck. Every
              project in my portfolio exists because I saw a problem and decided to
              solve it.
            </p>

            <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
              Outside of code, I enjoy exploring new technologies, contributing to
              open source, and finding creative solutions to everyday problems. I'm
              drawn to work that's technically interesting and meaningfully useful.
            </p>
          </div>

          <!-- Closing statement — left border accent pull-quote -->
          <div class="mt-10 md:mt-16 border-l-2 border-accent pl-6 md:pl-8">
            <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
              I'm currently looking for a software engineering role where I can
              contribute to a team building something that matters.
            </p>
          </div>

          <!-- Mobile-only metadata (hidden on desktop where sidebar shows) -->
          <div class="md:hidden mt-12 flex flex-wrap gap-x-8 gap-y-4 text-[length:var(--token-text-sm)]">
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Focus</span>
              <span class="font-body text-text-primary">Full-Stack Development</span>
            </div>
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Education</span>
              <span class="font-body text-text-primary">Computer Science</span>
            </div>
            <div>
              <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-1">Interests</span>
              <span class="font-body text-text-primary">Open Source, New Tech</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SKILLS — Editorial typographic list, NOT a card grid
       Each category as a display-scale serif word with skills as inline body text
       Separated by thin horizontal rules, left-aligned, no cards, no backgrounds
       Inspired by wam.global hierarchy + artemshcherban.com typography
       ═══════════════════════════════════════════ -->
  <section
    aria-label="Skills"
    class="relative border-t border-border"
    style="padding-top: clamp(4rem, 3rem + 5vw, 10rem); padding-bottom: clamp(4rem, 3rem + 5vw, 10rem);"
  >
    <div class="px-6 md:px-12 lg:px-20">
      <!-- Section label — wide, then content narrow and offset -->
      <span class="block font-mono text-[0.65rem] text-text-muted uppercase tracking-[0.3em] mb-16 md:mb-24">
        What I Work With
      </span>

      <!-- Skills as editorial typographic list -->
      <div class="md:ml-[15vw] lg:ml-[20vw] max-w-3xl space-y-0">

        <!-- Languages -->
        <div class="group border-t border-border py-8 md:py-10 md:grid md:grid-cols-[12rem_1fr] md:gap-8 items-baseline">
          <h3 class="font-display text-[length:var(--token-text-heading)] text-text-primary mb-3 md:mb-0">
            Languages
          </h3>
          <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
            TypeScript, JavaScript, Python, SQL, HTML, CSS
          </p>
        </div>

        <!-- Frameworks -->
        <div class="group border-t border-border py-8 md:py-10 md:grid md:grid-cols-[12rem_1fr] md:gap-8 items-baseline">
          <h3 class="font-display text-[length:var(--token-text-heading)] text-text-primary mb-3 md:mb-0">
            Frameworks
          </h3>
          <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
            React, Next.js, Astro, Node.js, Express
          </p>
        </div>

        <!-- Tools -->
        <div class="group border-t border-border py-8 md:py-10 md:grid md:grid-cols-[12rem_1fr] md:gap-8 items-baseline">
          <h3 class="font-display text-[length:var(--token-text-heading)] text-text-primary mb-3 md:mb-0">
            Tools
          </h3>
          <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
            Git, Docker, PostgreSQL, VS Code, Linux
          </p>
        </div>

        <!-- Concepts -->
        <div class="group border-t border-border border-b py-8 md:py-10 md:grid md:grid-cols-[12rem_1fr] md:gap-8 items-baseline">
          <h3 class="font-display text-[length:var(--token-text-heading)] text-text-primary mb-3 md:mb-0">
            Concepts
          </h3>
          <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.8]">
            REST APIs, CI/CD, Testing, Responsive Design, Accessibility
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA — Minimal text links at display scale
       Matching the editorial tone, no boxes
       ═══════════════════════════════════════════ -->
  <section
    aria-label="Next steps"
    class="border-t border-border"
    style="padding-top: clamp(3rem, 2rem + 4vw, 8rem); padding-bottom: clamp(3rem, 2rem + 4vw, 8rem);"
  >
    <div class="px-6 md:px-12 lg:px-20 flex flex-col md:flex-row md:items-center gap-6 md:gap-16">
      <a href="/contact" class="group inline-flex items-center gap-4">
        <span class="font-display text-[length:var(--token-text-heading)] text-text-primary group-hover:text-accent transition-colors duration-300">Get in Touch</span>
        <span class="block w-8 h-px bg-text-muted group-hover:w-14 group-hover:bg-accent transition-all duration-500" aria-hidden="true"></span>
      </a>
      <a href="/resume" class="group inline-flex items-center gap-4">
        <span class="font-display text-[length:var(--token-text-heading)] text-text-primary group-hover:text-accent transition-colors duration-300">Resume</span>
        <span class="block w-8 h-px bg-text-muted group-hover:w-14 group-hover:bg-accent transition-all duration-500" aria-hidden="true"></span>
      </a>
    </div>
  </section>
</BaseLayout>
