---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillGroup from "../components/SkillGroup.astro";
---

<BaseLayout
  title="About"
  description="Learn about Jack Cutrara's background, education, and path into software engineering."
>
  <!-- Page Header -->
  <section class="pt-[var(--token-space-section)] pb-[var(--token-space-3xl)] px-6 md:px-10 lg:px-16">
    <div class="max-w-[90rem] mx-auto">
      <p class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.1em] mb-[var(--token-space-lg)]">
        About
      </p>
      <h1 data-animate="split-text" class="font-display text-[length:var(--token-text-display)] tracking-[-0.03em] leading-[0.95] max-w-4xl">
        I build things that work.
      </h1>
    </div>
  </section>

  <!-- Narrative Section -->
  <section aria-label="Background" data-animate="section" class="pb-[var(--token-space-section)] px-6 md:px-10 lg:px-16">
    <div class="max-w-[90rem] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-[var(--token-space-3xl)]">
      <!-- Left column: label -->
      <div>
        <p class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.08em]">
          Background
        </p>
      </div>

      <!-- Right column: narrative -->
      <div class="max-w-2xl">
        <p class="font-body text-[length:var(--token-text-heading)] text-text-primary leading-[1.5] mb-[var(--token-space-xl)]">
          I'm Jack Cutrara, a software engineer based in New York. I got into
          programming because I wanted to build things &mdash; not just read about
          them.
        </p>
        <p class="font-body text-[length:var(--token-text-base)] text-text-secondary leading-[1.7] mb-[var(--token-space-lg)]">
          I studied computer science at university, where I discovered that the
          best way to learn was to ship real projects. That mindset stuck. Every
          project in my portfolio exists because I saw a problem and decided to
          solve it.
        </p>
        <p class="font-body text-[length:var(--token-text-base)] text-text-secondary leading-[1.7] mb-[var(--token-space-lg)]">
          Outside of code, I enjoy exploring new technologies, contributing to
          open source, and finding creative solutions to everyday problems. I'm
          drawn to work that's technically interesting and meaningfully useful.
        </p>
        <p class="font-body text-[length:var(--token-text-base)] text-text-primary leading-[1.7]">
          I'm currently looking for a software engineering role where I can
          contribute to a team building something that matters.
        </p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="px-6 md:px-10 lg:px-16">
    <div class="max-w-[90rem] mx-auto border-t border-border/40"></div>
  </div>

  <!-- Skills Section -->
  <section aria-label="Skills" data-animate="section" class="py-[var(--token-space-section)] px-6 md:px-10 lg:px-16">
    <div class="max-w-[90rem] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-[var(--token-space-3xl)]">
      <!-- Left column: label -->
      <div>
        <p class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.08em]">
          What I work with
        </p>
      </div>

      <!-- Right column: skill groups -->
      <div data-animate-container="stagger" class="grid grid-cols-1 md:grid-cols-2 gap-x-[var(--token-space-xl)] gap-y-[var(--token-space-sm)]">
        <div data-animate="stagger-item">
          <SkillGroup
            title="Languages"
            skills={["TypeScript", "JavaScript", "Python", "SQL", "HTML", "CSS"]}
          />
        </div>
        <div data-animate="stagger-item">
          <SkillGroup
            title="Frameworks"
            skills={["React", "Next.js", "Astro", "Node.js", "Express"]}
          />
        </div>
        <div data-animate="stagger-item">
          <SkillGroup
            title="Tools"
            skills={["Git", "Docker", "PostgreSQL", "VS Code", "Linux"]}
          />
        </div>
        <div data-animate="stagger-item">
          <SkillGroup
            title="Concepts"
            skills={[
              "REST APIs",
              "CI/CD",
              "Testing",
              "Responsive Design",
              "Accessibility",
            ]}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
