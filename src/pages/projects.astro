---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import FeaturedProjectItem from "../components/FeaturedProjectItem.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
const featured = sorted.filter((p) => p.data.featured);
const editorial = sorted.filter((p) => !p.data.featured);
---

<BaseLayout
  title="Projects"
  description="Explore software engineering projects by Jack Cutrara, from web applications to developer tools."
>
  <!-- Page Header -->
  <section class="pt-[var(--token-space-section)] pb-[var(--token-space-3xl)] px-6 md:px-10 lg:px-16">
    <div class="max-w-[90rem] mx-auto">
      <p class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.1em] mb-[var(--token-space-lg)]">
        Projects
      </p>
      <h1 data-animate="split-text" class="font-display text-[length:var(--token-text-display)] tracking-[-0.03em] leading-[0.95] max-w-4xl">
        Things I've built.
      </h1>
    </div>
  </section>

  <!-- Featured Cards Grid -->
  <section aria-label="Featured projects" data-animate="section" class="pb-[var(--token-space-3xl)] px-6 md:px-10 lg:px-16">
    <h2 class="sr-only">Featured projects</h2>
    <div data-animate-container="stagger" class="max-w-[90rem] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[var(--token-space-xl)]">
      {featured.map((project) => (
        <div data-animate="stagger-item">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </section>

  <!-- Divider (only if editorial list exists) -->
  {editorial.length > 0 && (
    <div class="px-6 md:px-10 lg:px-16">
      <div class="max-w-[90rem] mx-auto border-t border-border/40"></div>
    </div>
  )}

  <!-- Editorial List Section -->
  {editorial.length > 0 && (
    <section aria-label="More projects" data-animate="section" class="py-[var(--token-space-section)] px-6 md:px-10 lg:px-16">
      <div class="max-w-[90rem] mx-auto">
        <h2 class="sr-only">More projects</h2>
        {editorial.map((project) => (
          <FeaturedProjectItem
            title={project.data.title}
            tagline={project.data.tagline}
            techStack={project.data.techStack}
            slug={project.id}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
