---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import ResumeEntry from "../components/ResumeEntry.astro";
---

<BaseLayout
  title="Resume"
  description="View and download Jack Cutrara's software engineering resume."
>
  <!-- Print-only header (visible only in @media print) -->
  <div class="print-only-header">
    <p class="font-display" style="font-size:16pt;font-weight:700;">
      Jack Cutrara — Software Engineer
    </p>
    <p class="font-mono" style="font-size:9pt;color:#666;margin-top:4px;">
      jack@jackcutrara.com | github.com/jackc625 | linkedin.com/in/jackcutrara
    </p>
  </div>

  <!-- Page Header with PDF Download -->
  <section
    class="px-6 py-[var(--token-space-section)] pb-[var(--token-space-2xl)] md:px-10 lg:px-16"
  >
    <div class="mx-auto max-w-[90rem]">
      <h1
        data-animate="split-text"
        class="font-display text-[length:var(--token-text-display)] tracking-[-0.03em]"
      >
        Resume
      </h1>
      <div data-no-print class="mt-[var(--token-space-lg)]">
        <CTAButton
          href="/resume.pdf"
          label="Download PDF"
          download={true}
          showDownloadIcon={true}
        />
      </div>
    </div>
  </section>

  <!-- Resume Content -->
  <section
    aria-label="Resume summary"
    data-animate="section"
    class="px-6 pb-[var(--token-space-section)] md:px-10 lg:px-16"
  >
    <div class="mx-auto max-w-3xl">
      <!-- Experience -->
      <div class="mb-[var(--token-space-2xl)]">
        <h2
          class="font-body text-text-primary border-border/40 mb-[var(--token-space-lg)] border-b pb-[var(--token-space-sm)] text-[length:var(--token-text-heading)] font-semibold"
        >
          Experience
        </h2>
        <ResumeEntry
          title="Software Engineering Intern"
          organization="Tech Company"
          date="Summer 2025"
          bullets={[
            "Built and deployed internal tool reducing manual data processing by 40%",
            "Collaborated with senior engineers on REST API design and implementation",
            "Wrote unit and integration tests achieving 85% code coverage",
          ]}
        />
        <ResumeEntry
          title="Freelance Web Developer"
          organization="Self-employed"
          date="2024 — Present"
          bullets={[
            "Designed and built responsive websites for local businesses using modern frameworks",
            "Managed full project lifecycle from requirements gathering to deployment",
          ]}
        />
      </div>

      <!-- Education -->
      <div class="mb-[var(--token-space-2xl)]">
        <h2
          class="font-body text-text-primary border-border/40 mb-[var(--token-space-lg)] border-b pb-[var(--token-space-sm)] text-[length:var(--token-text-heading)] font-semibold"
        >
          Education
        </h2>
        <ResumeEntry
          title="B.S. Computer Science"
          organization="University"
          date="2025"
          description="Relevant coursework: Data Structures, Algorithms, Database Systems, Software Engineering, Operating Systems"
        />
      </div>

      <!-- Technical Skills -->
      <div>
        <h2
          class="font-body text-text-primary border-border/40 mb-[var(--token-space-lg)] border-b pb-[var(--token-space-sm)] text-[length:var(--token-text-heading)] font-semibold"
        >
          Technical Skills
        </h2>
        <div class="flex flex-wrap gap-[var(--token-space-sm)]">
          {
            [
              "TypeScript",
              "JavaScript",
              "Python",
              "React",
              "Next.js",
              "Astro",
              "Node.js",
              "PostgreSQL",
              "Docker",
              "Git",
              "REST APIs",
              "CI/CD",
            ].map((skill) => (
              <span class="text-text-secondary border-border/40 rounded border px-[var(--token-space-sm)] py-1 font-mono text-[length:var(--token-text-sm)]">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
