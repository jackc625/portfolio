---
import { Font } from "astro:assets";
import { SEO } from "astro-seo";
import SkipToContent from "../components/SkipToContent.astro";
import Header from "../components/primitives/Header.astro";
import MobileMenu from "../components/primitives/MobileMenu.astro";
import Footer from "../components/primitives/Footer.astro";
import ChatWidget from "../components/chat/ChatWidget.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  ogType = "website",
  canonicalUrl,
  noindex = false,
} = Astro.props;

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") ?? "https://jackcutrara.com";
const currentUrl = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogTitle = title || "Jack Cutrara | Software Engineer";

// WR-03: Pass-through absolute URLs (e.g., CDN OG images) unchanged. Only
// prepend siteUrl for root-relative paths like "/og-default.png". Without
// this guard, `${siteUrl}${ogImage}` would corrupt absolute URLs into
// `https://jackcutrara.comhttps://cdn.example.com/hero.png`.
const resolveOg = (img: string) =>
  /^https?:\/\//i.test(img) ? img : `${siteUrl}${img}`;
const resolvedOgImage = resolveOg(ogImage);

// Phase 15 / D-03: Umami Cloud website ID. Public literal (visible in HTML
// to every visitor — Umami website IDs are not secrets, matching the CF
// Web Analytics token pattern). Jack replaces this placeholder with the
// real Umami Cloud UUID pre-deploy per .planning/phases/
// 15-analytics-instrumentation/15-01-PLAN.md user_setup.dashboard_config.
const WEBSITE_ID = "TODO_PHASE_15_UMAMI_ID";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <SEO
      title={title}
      titleTemplate="%s | Jack Cutrara"
      titleDefault="Jack Cutrara | Software Engineer"
      description={description}
      canonical={currentUrl}
      openGraph={{
        basic: {
          title: ogTitle,
          type: ogType,
          image: resolvedOgImage,
          url: currentUrl,
        },
        optional: {
          siteName: "Jack Cutrara",
          description,
        },
        image: {
          width: 1200,
          height: 630,
          alt: `${ogTitle} - Jack Cutrara Portfolio`,
          type: "image/png",
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: ogTitle,
        description,
        image: resolvedOgImage,
        imageAlt: `${ogTitle} - Jack Cutrara Portfolio`,
      }}
    />
    {/* Phase 15 ANAL-01 — Umami Cloud analytics tag (D-01 / D-02 / D-03). */}
    {/* PROD gate (D-01 belt-and-suspenders): tag absent from HTML on dev + preview. */}
    {/* Server-side hostname allow-list on the tag narrows ingest to prod. */}
    {/* Astro directive preserves external script tag + vendor attrs verbatim. */}
    {/* Non-blocking load via deferred script semantics (no parser block). */}
    {import.meta.env.PROD && (
      <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id={WEBSITE_ID} data-domains="jackcutrara.com" />
    )}
    <Font cssVariable="--font-display-src" />
    <Font cssVariable="--font-body-src" />
    <Font cssVariable="--font-mono-src" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <slot name="head" />
  </head>
  <body
    class="bg-bg text-ink font-body flex min-h-screen flex-col antialiased"
  >
    <SkipToContent />
    <Header />
    <MobileMenu />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <ChatWidget />
  </body>
</html>
