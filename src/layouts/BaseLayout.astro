---
import { Font } from "astro:assets";
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";
import SkipToContent from "../components/SkipToContent.astro";
import Header from "../components/Header.astro";
import MobileMenu from "../components/MobileMenu.astro";
import Footer from "../components/Footer.astro";
import ChatWidget from "../components/chat/ChatWidget.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") ?? "https://jackcutrara.com";
const currentUrl = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogTitle = title || "Jack Cutrara | Software Engineer";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "light" ||
          (!stored &&
            window.matchMedia("(prefers-color-scheme: light)").matches)
        ) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
      document.addEventListener("astro:after-swap", function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "light" ||
          (!stored &&
            window.matchMedia("(prefers-color-scheme: light)").matches)
        ) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      });
    </script>
    <SEO
      title={title}
      titleTemplate="%s | Jack Cutrara"
      titleDefault="Jack Cutrara | Software Engineer"
      description={description}
      canonical={currentUrl}
      openGraph={{
        basic: {
          title: ogTitle,
          type: ogType,
          image: `${siteUrl}${ogImage}`,
          url: currentUrl,
        },
        optional: {
          siteName: "Jack Cutrara",
          description,
        },
        image: {
          width: 1200,
          height: 630,
          alt: `${ogTitle} - Jack Cutrara Portfolio`,
          type: "image/png",
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: ogTitle,
        description,
        image: `${siteUrl}${ogImage}`,
        imageAlt: `${ogTitle} - Jack Cutrara Portfolio`,
      }}
    />
    <Font cssVariable="--font-heading" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-code" />
    <ClientRouter />
  </head>
  <body
    class="bg-bg-primary text-text-primary font-body flex min-h-screen flex-col antialiased"
  >
    <SkipToContent />
    <Header />
    <MobileMenu />
    <main id="main-content" class="flex-1 pt-14">
      <slot />
    </main>
    <Footer />
    <ChatWidget transition:persist />
    <script>
      document.addEventListener("astro:page-load", async () => {
        const { initAnimations } = await import("../scripts/animations.ts");
        await initAnimations();
      });

      document.addEventListener("astro:before-preparation", async () => {
        const { cleanupAnimations } = await import("../scripts/animations.ts");
        cleanupAnimations();
      });

      // Fallback: reveal content if GSAP fails to load after 3 seconds
      setTimeout(() => {
        document.querySelectorAll("[data-animate]").forEach((el) => {
          const computed = getComputedStyle(el);
          if (computed.opacity === "0") {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
          }
        });
      }, 3000);
    </script>
  </body>
</html>
