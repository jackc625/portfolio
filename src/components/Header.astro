---
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/resume", label: "Resume" },
  { href: "/contact", label: "Contact" },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 border-b border-border/40"
>
  <div class="absolute inset-0 bg-bg-primary/80 backdrop-blur-md"></div>
  <nav
    aria-label="Main navigation"
    class="relative grid grid-cols-[1fr_auto_auto] md:grid-cols-[auto_1fr_auto] items-center gap-2 md:gap-0 h-14 px-6 md:px-10 lg:px-16 max-w-[90rem] mx-auto"
  >
    <a
      href="/"
      class="font-display text-[length:var(--token-text-base)] tracking-tight text-text-primary hover:text-accent transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none focus-visible:rounded"
    >
      Jack Cutrara
    </a>

    <div class="hidden md:block"></div>

    <ul class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => {
          const isActive =
            link.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(link.href);
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "text-[length:var(--token-text-sm)] font-body tracking-wide transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none focus-visible:rounded px-1 py-1",
                  isActive
                    ? "text-text-primary"
                    : "text-text-muted hover:text-text-primary nav-link-hover",
                ]}
                aria-current={isActive ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
      <li><ThemeToggle /></li>
    </ul>

    <div class="md:hidden"><ThemeToggle /></div>

    <button
      id="menu-trigger"
      class="md:hidden flex items-center justify-center w-10 h-10 text-text-primary focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none focus-visible:rounded"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="relative w-5 h-3.5 flex flex-col justify-between">
        <span
          class="hamburger-line block w-full h-[1.5px] bg-current transition-all duration-300 origin-center"
        ></span>
        <span
          class="hamburger-line block w-full h-[1.5px] bg-current transition-all duration-300 origin-center"
        ></span>
        <span
          class="hamburger-line block w-full h-[1.5px] bg-current transition-all duration-300 origin-center"
        ></span>
      </span>
    </button>
  </nav>
</header>

<style>
  #menu-trigger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  #menu-trigger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #menu-trigger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }
</style>
