---
// CanvasHero.astro — Full-viewport generative art canvas with content overlay
// Uses simplex-noise flow field for procedural visuals unique on every page load
// Canvas is decorative (aria-hidden), content overlays via <slot />
---

<section class="relative w-full h-screen overflow-hidden" aria-label="Introduction">
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>
  <div class="relative z-10 flex flex-col justify-end h-full pb-[var(--token-space-section)] px-6 md:px-10 lg:px-16">
    <slot />
  </div>
</section>

<script>
  import { createNoise2D } from 'simplex-noise';

  interface Particle {
    x: number;
    y: number;
    prevX: number;
    prevY: number;
    depth: number; // 0.5, 0.75, or 1.0
  }

  const depthValues = [0.5, 0.75, 1.0];

  function initCanvas(): (() => void) | undefined {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return undefined;
    const ctx = canvas.getContext('2d');
    if (!ctx) return undefined;
    const section = canvas.closest('section');
    if (!section) return undefined;

    const noise2D = createNoise2D();
    let animationId: number;
    let time = 0;
    const noiseScale = 0.0025;
    const speed = 1.2;

    // Determine particle count based on viewport (D-03: tiered mobile/tablet/desktop)
    const isMobile = window.innerWidth < 768;
    const isTablet = window.innerWidth >= 768 && window.innerWidth < 1024;
    const particleCount = isMobile ? 200 : isTablet ? 600 : 1000;

    let width = window.innerWidth;
    let height = window.innerHeight;
    let particles: Particle[] = [];

    // Mouse influence tracking (D-24)
    let mouseX = -1000;
    let mouseY = -1000;
    const mouseRadius = 400;
    const mouseInfluenceMax = 1.2;

    function onMouseMove(e: MouseEvent) {
      const rect = canvas!.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    }

    // Only add mouse tracking on hover-capable devices
    const hasHover = window.matchMedia('(hover: hover)').matches;
    if (hasHover) {
      section.addEventListener('mousemove', onMouseMove);
    }

    // Theme-aware trail color — adapts when theme switches (D-18)
    function getTrailColor(): string {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      return isLight ? 'rgba(246, 243, 235, 0.03)' : 'rgba(10, 10, 14, 0.03)';
    }

    function getOpaqueTrailColor(): string {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      return isLight ? 'rgba(246, 243, 235, 1)' : 'rgba(10, 10, 14, 1)';
    }

    // Extract accent color for stroke, or fallback
    const accentEl = document.createElement('div');
    accentEl.style.color = 'var(--token-accent)';
    document.body.appendChild(accentEl);
    const computedAccent = getComputedStyle(accentEl).color;
    document.body.removeChild(accentEl);

    // Parse the computed accent color to get RGBA values
    function parseColor(color: string): { r: number; g: number; b: number } {
      const match = color.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
      if (match) {
        return { r: parseInt(match[1]), g: parseInt(match[2]), b: parseInt(match[3]) };
      }
      // Fallback: muted blue matching accent token
      return { r: 130, g: 150, b: 220 };
    }

    const accent = parseColor(computedAccent);

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      width = window.innerWidth;
      height = window.innerHeight;
      canvas!.width = width * dpr;
      canvas!.height = height * dpr;
      canvas!.style.width = width + 'px';
      canvas!.style.height = height + 'px';
      ctx!.scale(dpr, dpr);
      initParticles();
    }

    function initParticles() {
      particles = [];
      for (let i = 0; i < particleCount; i++) {
        const x = Math.random() * width;
        const y = Math.random() * height;
        const depth = depthValues[Math.floor(Math.random() * depthValues.length)];
        particles.push({ x, y, prevX: x, prevY: y, depth });
      }
    }

    function draw() {
      // Semi-transparent fill creates trail effect
      ctx!.fillStyle = getTrailColor();
      ctx!.fillRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.prevX = p.x;
        p.prevY = p.y;

        let angle = noise2D(p.x * noiseScale, p.y * noiseScale + time * 0.0001) * Math.PI * 2;

        // Mouse influence (D-24): particles near cursor are repelled away
        const dx = mouseX - p.x;
        const dy = mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        let speedMult = 1;
        if (dist < mouseRadius) {
          const influence = (1 - dist / mouseRadius) * mouseInfluenceMax;
          // Steer angle AWAY from mouse (repulsion)
          const awayAngle = Math.atan2(-dy, -dx);
          let angleDiff = awayAngle - angle;
          while (angleDiff > Math.PI) angleDiff -= 2 * Math.PI;
          while (angleDiff < -Math.PI) angleDiff += 2 * Math.PI;
          angle += angleDiff * influence;
          // Accelerate particles near cursor so the push is visible
          speedMult = 1 + influence * 3;
        }

        // Depth-scaled movement: deeper particles move slower
        p.x += Math.cos(angle) * speed * p.depth * speedMult;
        p.y += Math.sin(angle) * speed * p.depth * speedMult;

        // Wrap around edges
        if (p.x < 0) p.x = width;
        if (p.x > width) p.x = 0;
        if (p.y < 0) p.y = height;
        if (p.y > height) p.y = 0;

        // Depth-varied stroke style and line width
        const strokeOpacity = 0.3 * p.depth;
        ctx!.strokeStyle = `rgba(${accent.r}, ${accent.g}, ${accent.b}, ${strokeOpacity})`;
        ctx!.lineWidth = p.depth === 0.5 ? 0.5 : p.depth === 0.75 ? 0.8 : 1.2;

        ctx!.beginPath();
        ctx!.moveTo(p.prevX, p.prevY);
        ctx!.lineTo(p.x, p.y);
        ctx!.stroke();
      }

      time++;
      animationId = requestAnimationFrame(draw);
    }

    function drawStaticFrame() {
      // For reduced-motion users: draw a single static noise-based pattern
      ctx!.fillStyle = getOpaqueTrailColor();
      ctx!.fillRect(0, 0, width, height);

      // Draw scattered dots with depth-varied opacity
      for (let i = 0; i < particleCount; i++) {
        const x = Math.random() * width;
        const y = Math.random() * height;
        const depth = depthValues[Math.floor(Math.random() * depthValues.length)];
        const noiseVal = noise2D(x * noiseScale, y * noiseScale);
        const opacity = Math.abs(noiseVal) * 0.3 * depth;

        ctx!.fillStyle = `rgba(${accent.r}, ${accent.g}, ${accent.b}, ${opacity})`;
        ctx!.beginPath();
        ctx!.arc(x, y, 1 + Math.abs(noiseVal) * 2, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    // Initialize
    resize();

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      drawStaticFrame();
    } else {
      animationId = requestAnimationFrame(draw);
    }

    // Resize handler
    const onResize = () => {
      resize();
      if (prefersReducedMotion) {
        drawStaticFrame();
      }
    };
    window.addEventListener('resize', onResize);

    // Return cleanup function for View Transitions
    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', onResize);
      if (hasHover) {
        section.removeEventListener('mousemove', onMouseMove);
      }
    };
  }

  // View Transitions lifecycle — initialize on page load, clean up before navigation
  let cleanup: (() => void) | undefined;

  function handleThemeChange() {
    cleanup?.();
    cleanup = initCanvas() || undefined;
  }

  document.addEventListener('astro:page-load', () => {
    cleanup?.();
    cleanup = initCanvas() || undefined;
  });

  document.addEventListener('astro:before-preparation', () => {
    cleanup?.();
    cleanup = undefined;
  });

  window.addEventListener('theme-changed', handleThemeChange);
</script>
