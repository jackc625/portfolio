---
interface Props {
  title: string;
  organization: string;
  date: string;
  description?: string;
  bullets?: string[];
}
const { title, organization, date, description, bullets } = Astro.props;
---

<div class="mb-[var(--token-space-xl)] border-l-2 border-accent/40 pl-[var(--token-space-lg)]">
  <div class="flex flex-col gap-[var(--token-space-xs)]">
    <h3 class="font-body text-[length:var(--token-text-base)] font-semibold text-text-primary">{title}</h3>
    <span class="font-mono text-[length:var(--token-text-sm)] text-text-muted">{organization} &middot; {date}</span>
  </div>
  {description && (
    <p class="font-body text-[length:var(--token-text-base)] text-text-secondary mt-[var(--token-space-sm)] leading-[1.6]">{description}</p>
  )}
  {bullets && bullets.length > 0 && (
    <ul class="mt-[var(--token-space-sm)] space-y-1">
      {bullets.map((bullet) => (
        <li class="font-body text-[length:var(--token-text-sm)] text-text-secondary leading-[1.6]">&mdash; {bullet}</li>
      ))}
    </ul>
  )}
</div>
