---
interface Props {
  title: string;
  organization: string;
  date: string;
  description?: string;
  bullets?: string[];
}
const { title, organization, date, description, bullets } = Astro.props;
---

<div
  class="border-accent/40 mb-[var(--token-space-xl)] border-l-2 pl-[var(--token-space-lg)]"
>
  <div class="flex flex-col gap-[var(--token-space-xs)]">
    <h3
      class="font-body text-text-primary text-[length:var(--token-text-base)] font-semibold"
    >
      {title}
    </h3>
    <span class="text-text-muted font-mono text-[length:var(--token-text-sm)]"
      >{organization} &middot; {date}</span
    >
  </div>
  {
    description && (
      <p class="font-body text-text-secondary mt-[var(--token-space-sm)] text-[length:var(--token-text-base)] leading-[1.6]">
        {description}
      </p>
    )
  }
  {
    bullets && bullets.length > 0 && (
      <ul class="mt-[var(--token-space-sm)] space-y-1">
        {bullets.map((bullet) => (
          <li class="font-body text-text-secondary text-[length:var(--token-text-sm)] leading-[1.6]">
            &mdash; {bullet}
          </li>
        ))}
      </ul>
    )
  }
</div>
