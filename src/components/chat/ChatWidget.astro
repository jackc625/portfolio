---
// ChatWidget.astro — Floating chat bubble + expandable chat panel
// Injected in BaseLayout.astro before </body>, after Footer
// Phase 10: Restyled to editorial flat-rectangle chrome (D-15 through D-20)
// Phase 8: transition:persist removed with ClientRouter (D-29) — cross-page chat persistence descoped to Phase 10 CHAT-01
// All sub-components inline (single file per established pattern)
---

<div class="chat-widget" data-no-print>
  <!-- Floating Bubble (D-15: only round surface in editorial system) -->
  <button
    type="button"
    id="chat-bubble"
    style="position: fixed; z-index: 50; bottom: 24px; right: 24px; width: 48px; height: 48px; background: var(--accent); border-radius: 50%; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;"
    aria-label="Open chat"
    aria-expanded="false"
  >
    <!-- Message bubble icon (24px, white) -->
    <svg
      id="chat-bubble-icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <!-- Close icon (hidden by default, shown when panel open) -->
    <svg
      id="chat-bubble-close-icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      style="display: none;"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Chat Panel (D-15: flat rectangle, no shadow, 1px rule border) -->
  <div
    id="chat-panel"
    style="display: none; position: fixed; bottom: 84px; right: 24px; z-index: 50; width: 400px; height: 500px; background: var(--bg); border: 1px solid var(--rule); border-radius: 0; box-shadow: none; flex-direction: column; overflow: hidden;"
    role="dialog"
    aria-modal="true"
    aria-label="Chat with Jack's AI"
  >
    <!-- Chat Header (D-15: label-mono text + 1px rule bottom) -->
    <div
      style="height: 48px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; border-bottom: 1px solid var(--rule); flex-shrink: 0;"
    >
      <span class="label-mono" style="color: var(--ink);">
        ASK ABOUT JACK
      </span>
      <button
        type="button"
        id="chat-close"
        style="min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer; font-size: 1.25rem; color: var(--ink-faint);"
        aria-label="Close chat"
      >&times;</button>
    </div>

    <!-- Message Area -->
    <div
      id="chat-messages"
      style="flex: 1; overflow-y: auto; padding: 16px;"
      aria-live="polite"
      role="log"
    >
      <!-- Starter Chips (D-16: flat editorial buttons) -->
      <div
        id="chat-starters"
        style="display: flex; flex-wrap: wrap; gap: 8px;"
      >
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
        >
          What projects have you built?
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
        >
          What's your tech stack?
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
        >
          Tell me about your experience
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
        >
          What makes you stand out?
        </button>
      </div>

      <!-- Typing Indicator (D-17) — hidden by default, CSS keyframes in global.css -->
      <div
        id="chat-typing"
        style="display: none; padding: 8px 0 8px 12px; border-left: 2px solid var(--rule); gap: 4px; align-items: center;"
      >
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
      </div>
    </div>

    <!-- Input Area (D-16: flat rule borders, accent focus ring) -->
    <div
      style="flex-shrink: 0; border-top: 1px solid var(--rule); padding: 12px 16px; background: var(--bg);"
    >
      <div style="display: flex; align-items: flex-end; gap: 8px;">
        <div style="flex: 1; display: flex; flex-direction: column;">
          <textarea
            id="chat-input"
            class="chat-textarea"
            placeholder="Ask me anything..."
            rows="1"
            maxlength="500"
          ></textarea>
          <div
            id="chat-char-count"
            style="display: none; text-align: right; font-size: 0.875rem; color: var(--ink-faint); margin-top: 2px;"
          ></div>
        </div>
        <button
          type="button"
          id="chat-send"
          style="width: 36px; height: 36px; border-radius: 0; background: transparent; border: none; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--ink-faint); opacity: 0.4; cursor: not-allowed;"
          aria-label="Send message"
          disabled
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="12" y1="19" x2="12" y2="5"></line>
            <polyline points="5 12 12 5 19 12"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <!-- Privacy Note (D-22) — Updated in Plan 06 after localStorage persistence implemented -->
    <div
      style="font-size: 0.875rem; color: var(--ink-faint); text-align: center; padding: 4px 0 8px 0;"
    >
      Conversations stored locally for 24h.
    </div>
  </div>
</div>

<script>
  import "../../scripts/chat.ts";
</script>
