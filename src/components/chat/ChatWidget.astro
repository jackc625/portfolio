---
// ChatWidget.astro — Floating chat bubble + expandable chat panel
// Injected in BaseLayout.astro before </body>, after Footer
// Phase 8: transition:persist removed with ClientRouter (D-29) — cross-page chat persistence descoped to Phase 10 CHAT-01
// All sub-components inline (single file per established pattern)
---

<div class="chat-widget" data-no-print>
  <!-- Floating Bubble (D-01, D-03) -->
  <button
    type="button"
    id="chat-bubble"
    class="fixed z-50 flex items-center justify-center rounded-full"
    style="bottom: 24px; right: 24px; width: 48px; height: 48px; background: var(--token-accent);"
    aria-label="Open chat"
    aria-expanded="false"
  >
    <!-- Message bubble icon (24px, white) -->
    <svg
      id="chat-bubble-icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <!-- Close icon (hidden by default, shown when panel open) -->
    <svg
      id="chat-bubble-close-icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      style="display: none;"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Chat Panel (D-02, D-05, D-06) -->
  <div
    id="chat-panel"
    class="fixed z-49 flex flex-col overflow-hidden"
    style="display: none; bottom: 80px; right: 24px; width: 400px; height: 500px; background: var(--token-bg-primary); border: 1px solid var(--token-border); border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.25);"
    role="dialog"
    aria-label="Chat with Jack's AI"
  >
    <!-- Chat Header -->
    <div
      class="flex items-center justify-between shrink-0"
      style="height: 48px; background: var(--token-bg-secondary); border-bottom: 1px solid var(--token-border); padding: 0 var(--token-space-md);"
    >
      <span
        style="font-size: var(--token-text-sm); font-weight: 600; color: var(--token-text-primary);"
      >
        Ask Jack's AI
      </span>
      <button
        type="button"
        id="chat-close"
        class="flex items-center justify-center"
        style="min-width: 44px; min-height: 44px;"
        aria-label="Close chat"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          style="color: var(--token-text-muted);"
          class="hover-text-primary"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Message Area (D-32) -->
    <div
      id="chat-messages"
      class="flex-1 overflow-y-auto"
      style="padding: var(--token-space-md);"
      aria-live="polite"
      role="log"
    >
      <!-- Starter Chips (D-27) -->
      <div
        id="chat-starters"
        class="flex flex-wrap"
        style="gap: var(--token-space-sm);"
      >
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
          style="background: var(--token-bg-secondary); border: 1px solid var(--token-border); border-radius: 9999px; padding: 8px 12px; font-size: var(--token-text-sm); font-weight: 400; color: var(--token-text-secondary); cursor: pointer;"
        >
          What projects have you built?
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
          style="background: var(--token-bg-secondary); border: 1px solid var(--token-border); border-radius: 9999px; padding: 8px 12px; font-size: var(--token-text-sm); font-weight: 400; color: var(--token-text-secondary); cursor: pointer;"
        >
          What's your tech stack?
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
          style="background: var(--token-bg-secondary); border: 1px solid var(--token-border); border-radius: 9999px; padding: 8px 12px; font-size: var(--token-text-sm); font-weight: 400; color: var(--token-text-secondary); cursor: pointer;"
        >
          Tell me about your experience
        </button>
        <button
          type="button"
          class="chat-starter-chip"
          role="button"
          tabindex="0"
          style="background: var(--token-bg-secondary); border: 1px solid var(--token-border); border-radius: 9999px; padding: 8px 12px; font-size: var(--token-text-sm); font-weight: 400; color: var(--token-text-secondary); cursor: pointer;"
        >
          What makes you stand out?
        </button>
      </div>

      <!-- Typing Indicator (D-28) — hidden by default -->
      <div
        id="chat-typing"
        class="flex items-center"
        style="display: none; padding: 8px 0 8px 12px; border-left: 2px solid var(--token-border); gap: 4px;"
      >
        <span class="typing-dot" style="animation-delay: 0ms;"></span>
        <span class="typing-dot" style="animation-delay: 150ms;"></span>
        <span class="typing-dot" style="animation-delay: 300ms;"></span>
      </div>
    </div>

    <!-- Input Area (D-34, D-35) -->
    <div
      class="shrink-0"
      style="border-top: 1px solid var(--token-border); padding: 12px var(--token-space-md); background: var(--token-bg-primary);"
    >
      <div class="flex items-end" style="gap: var(--token-space-sm);">
        <div class="flex-1 flex flex-col">
          <textarea
            id="chat-input"
            class="chat-textarea w-full"
            placeholder="Ask me anything..."
            rows="1"
            maxlength="500"
            style="background: var(--token-bg-secondary); border: 1px solid var(--token-border); border-radius: 8px; padding: 8px 12px; font-family: var(--font-body); font-size: var(--token-text-base); color: var(--token-text-primary); outline: none;"
          ></textarea>
          <div
            id="chat-char-count"
            style="display: none; text-align: right; font-size: var(--token-text-sm); color: var(--token-text-muted); margin-top: 2px;"
          ></div>
        </div>
        <button
          type="button"
          id="chat-send"
          class="flex items-center justify-center shrink-0 rounded-full"
          style="width: 36px; height: 36px; background: var(--token-accent); opacity: 0.4; cursor: not-allowed;"
          aria-label="Send message"
          disabled
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="12" y1="19" x2="12" y2="5"></line>
            <polyline points="5 12 12 5 19 12"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <!-- Privacy Note (D-37) -->
    <div
      style="font-size: var(--token-text-sm); color: var(--token-text-muted); text-align: center; padding: 4px 0 8px 0;"
    >
      Conversations are not stored.
    </div>
  </div>
</div>

<script>
  import "../../scripts/chat.ts";
</script>
