---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<section class="bg-rule">
  <a
    href={`/projects/${project.id}`}
    class="group focus-visible:outline-accent block px-6 py-24 focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 md:px-10 lg:px-16"
  >
    <div class="mx-auto max-w-[90rem]">
      <p
        class="text-ink-faint mb-6 font-mono text-sm tracking-[0.08em] uppercase"
      >
        Next Project
      </p>
      <div class="flex items-center gap-6">
        <span
          class="font-display text-ink group-hover:text-accent text-3xl transition-colors duration-200"
        >
          {project.data.title}
        </span>
        <svg
          class="text-ink-faint group-hover:text-accent h-6 w-6 transition-all duration-200 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </div>
    </div>
  </a>
</section>
