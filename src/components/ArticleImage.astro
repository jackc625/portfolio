---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: string | ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;
---

<figure class="my-8">
  {
    typeof src === "string" ? (
      <img
        src={src}
        alt={alt}
        class="aspect-video w-full rounded object-cover"
        loading="lazy"
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        class="aspect-video w-full rounded object-cover"
      />
    )
  }
  {
    alt && (
      <figcaption class="text-ink-faint mt-2 font-mono text-sm">
        {alt}
      </figcaption>
    )
  }
</figure>
