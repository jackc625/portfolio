---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: string | ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;
---

<figure class="my-[var(--token-space-xl)]">
  {
    typeof src === "string" ? (
      <img
        src={src}
        alt={alt}
        class="aspect-video w-full rounded object-cover"
        loading="lazy"
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        class="aspect-video w-full rounded object-cover"
      />
    )
  }
  {
    alt && (
      <figcaption class="text-text-muted mt-[var(--token-space-sm)] font-mono text-[length:var(--token-text-sm)]">
        {alt}
      </figcaption>
    )
  }
</figure>
