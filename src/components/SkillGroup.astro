---
interface Props {
  title: string;
  skills: string[];
}

const { title, skills } = Astro.props;
---

<div class="mb-[var(--token-space-xl)]">
  <h3
    class="text-text-muted mb-[var(--token-space-md)] font-mono text-[length:var(--token-text-sm)] tracking-[0.08em] uppercase"
  >
    {title}
  </h3>
  <div class="flex flex-wrap gap-[var(--token-space-sm)]">
    {
      skills.map((skill) => (
        <span class="font-body text-text-primary border-border/60 hover:border-border-hover hover:text-accent rounded-full border px-3 py-1 text-[length:var(--token-text-sm)] transition-colors duration-200">
          {skill}
        </span>
      ))
    }
  </div>
</div>
