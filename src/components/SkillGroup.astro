---
interface Props {
  title: string;
  skills: string[];
}

const { title, skills } = Astro.props;
---

<div class="mb-[var(--token-space-xl)]">
  <h3
    class="font-mono text-[length:var(--token-text-sm)] text-text-muted uppercase tracking-[0.08em] mb-[var(--token-space-md)]"
  >
    {title}
  </h3>
  <div class="flex flex-wrap gap-[var(--token-space-sm)]">
    {
      skills.map((skill) => (
        <span class="font-body text-[length:var(--token-text-sm)] text-text-primary border border-border/60 rounded-full px-3 py-1 transition-colors duration-200 hover:border-border-hover hover:text-accent">
          {skill}
        </span>
      ))
    }
  </div>
</div>
