---
interface Props {
  href: string;
  label: string;
  download?: boolean;
  showDownloadIcon?: boolean;
}
const { href, label, download = false, showDownloadIcon = false } = Astro.props;
---

<a
  href={href}
  download={download || undefined}
  aria-label={download ? `Download ${label}` : undefined}
  class="inline-flex items-center gap-[var(--token-space-sm)] text-accent hover:text-accent-hover
         font-body text-[length:var(--token-text-sm)] font-medium uppercase tracking-[0.08em]
         transition-colors duration-200
         focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none focus-visible:rounded
         border-b border-accent/30 hover:border-accent pb-1"
>
  {label}
  {showDownloadIcon && (
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" y1="15" x2="12" y2="3" />
    </svg>
  )}
</a>
